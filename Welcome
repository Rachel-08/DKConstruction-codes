"use client";

import { useRef, useState } from "react";
import { motion } from "motion/react";

type WelcomeIntroProps = {
  onEnter: () => void;
  viewImage: string;
};

type RectType = {
  top: number;
  left: number;
  width: number;
  height: number;
};

export default function WelcomeIntro({
  onEnter,
  viewImage,
}: WelcomeIntroProps) {
  const glassRef = useRef<HTMLDivElement | null>(null);

  const [phase, setPhase] = useState<"idle" | "opening" | "zooming">("idle");
  const [zoomRect, setZoomRect] = useState<RectType | null>(null);

  const isOpening = phase === "opening" || phase === "zooming";
  const isZooming = phase === "zooming";

  const handleEnter = () => {
    if (phase !== "idle") return;

    setPhase("opening");

    setTimeout(() => {
      if (glassRef.current) {
        const rect = glassRef.current.getBoundingClientRect();
        setZoomRect({
          top: rect.top,
          left: rect.left,
          width: rect.width,
          height: rect.height,
        });
      }

      setPhase("zooming");

      setTimeout(() => {
        onEnter();
      }, 950);
    }, 850);
  };

  return (
    <motion.section
      initial={{ opacity: 1 }}
      exit={{
        opacity: 0,
        transition: {
          duration: 0.45,
          ease: [0.76, 0, 0.24, 1],
        },
      }}
      className="fixed inset-0 z-[100] overflow-hidden bg-[#b8a487] text-[#3f3a32]"
    >
      {/* Expanding fullscreen background from the window view */}
      {zoomRect && (
        <motion.div
          initial={{
            top: zoomRect.top,
            left: zoomRect.left,
            width: zoomRect.width,
            height: zoomRect.height,
            opacity: 1,
          }}
          animate={{
            top: 0,
            left: 0,
            width: "100vw",
            height: "100vh",
            opacity: 1,
          }}
          transition={{
            duration: 1,
            ease: [0.76, 0, 0.24, 1],
          }}
          className="pointer-events-none fixed z-[90] overflow-hidden"
        >
          <div
            className="absolute inset-0 bg-cover bg-center"
            style={{ backgroundImage: `url("${viewImage}")` }}
          />
          <div className="absolute inset-0 bg-black/10" />
        </motion.div>
      )}

      {/* Browser top bar */}
      <motion.div
        animate={{
          opacity: isZooming ? 0 : 1,
          y: isZooming ? -20 : 0,
        }}
        transition={{ duration: 0.35 }}
        className="absolute left-0 top-0 z-50 h-[56px] w-full bg-[#2b2b2b] shadow-md"
      >
        <div className="relative flex h-full items-center px-5">
          <div className="flex gap-2">
            <span className="h-3 w-3 rounded-full bg-[#ff6b5f]" />
            <span className="h-3 w-3 rounded-full bg-[#f4c05d]" />
            <span className="h-3 w-3 rounded-full bg-[#61c66b]" />
          </div>

          <div className="ml-8 flex gap-2 text-[#aaa]">
            <button className="flex h-8 w-8 items-center justify-center rounded-full bg-[#3a3a3a]">
              ‹
            </button>
            <button className="flex h-8 w-8 items-center justify-center rounded-full bg-[#3a3a3a]">
              ›
            </button>
          </div>

          <div className="absolute left-1/2 top-1/2 flex h-8 w-[45%] -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-lg bg-[#3a3a3a] text-sm text-[#d8d8d8]">
            <span className="mr-2 text-xs">🔒</span>
            dkstudio.com
          </div>

          <div className="ml-auto flex gap-5 text-2xl text-[#d7d7d7]">
            <span>⌘</span>
            <span>＋</span>
            <span>□</span>
          </div>
        </div>
      </motion.div>

      {/* Main wall */}
      <div className="relative min-h-screen pt-[56px]">
        {/* Wall gradient */}
        <motion.div
          animate={{ opacity: isZooming ? 0 : 0.24 }}
          transition={{ duration: 0.4 }}
          className="pointer-events-none absolute inset-0"
        >
          <div className="h-full w-full bg-[radial-gradient(circle_at_25%_20%,rgba(255,255,255,0.38),transparent_30%),radial-gradient(circle_at_80%_70%,rgba(0,0,0,0.28),transparent_38%)]" />
        </motion.div>

        {/* Texture */}
        <motion.div
          animate={{ opacity: isZooming ? 0 : 0.16 }}
          transition={{ duration: 0.4 }}
          className="pointer-events-none absolute inset-0 bg-[linear-gradient(45deg,rgba(255,255,255,0.24)_25%,transparent_25%),linear-gradient(-45deg,rgba(0,0,0,0.12)_25%,transparent_25%)] bg-[length:8px_8px]"
        />

        {/* Floor line */}
        <motion.div
          animate={{ opacity: isZooming ? 0 : 1 }}
          transition={{ duration: 0.35 }}
          className="absolute bottom-10 left-0 h-px w-full bg-black/20"
        />

        {/* Floor */}
        <motion.div
          animate={{ opacity: isZooming ? 0 : 1 }}
          transition={{ duration: 0.35 }}
          className="absolute bottom-0 left-0 h-10 w-full bg-[#9d927f]"
        >
          <div className="h-full w-full bg-[linear-gradient(90deg,transparent_0%,transparent_18%,rgba(0,0,0,0.18)_18.2%,transparent_18.4%,transparent_54%,rgba(0,0,0,0.18)_54.2%,transparent_54.4%)]" />
        </motion.div>

        <motion.div
          animate={{
            opacity: isZooming ? 0 : 1,
            scale: isZooming ? 1.03 : 1,
          }}
          transition={{
            duration: 0.45,
            ease: [0.76, 0, 0.24, 1],
          }}
          className="relative z-10 grid min-h-[calc(100vh-56px)] grid-cols-[48%_52%] items-center px-[9vw]"
        >
          {/* Left clickable window */}
          <motion.button
            type="button"
            onClick={handleEnter}
            whileHover={!isOpening ? { scale: 1.02 } : undefined}
            whileTap={!isOpening ? { scale: 0.98 } : undefined}
            className="relative flex cursor-pointer justify-center outline-none"
          >
            <div className="relative h-[72vh] min-h-[500px] w-[330px] bg-[#241f19] p-[28px] shadow-[0_18px_45px_rgba(0,0,0,0.45)]">
              {/* Wall recess */}
              <div className="absolute -inset-[34px] -z-10 bg-[#a58f72] shadow-[inset_18px_18px_30px_rgba(0,0,0,0.34),inset_-10px_-10px_24px_rgba(255,255,255,0.16)]" />

              {/* Outer frame */}
              <div className="relative h-full w-full border-[10px] border-[#11100e] bg-[#1a1714] p-3 shadow-[inset_0_0_20px_rgba(0,0,0,0.9)]">
                {/* Glass */}
                <div
                  ref={glassRef}
                  style={{ perspective: 1200 }}
                  className="relative h-full w-full overflow-hidden border-2 border-[#090807] bg-[#b8b4a6]"
                >
                  {/* Shared background image inside glass */}
                  <div
                    className="absolute inset-0 bg-cover bg-center"
                    style={{ backgroundImage: `url("${viewImage}")` }}
                  />

                  {/* Reflection overlay */}
                  <div className="absolute inset-0 bg-[linear-gradient(110deg,rgba(255,255,255,0.4)_0%,rgba(255,255,255,0.18)_34%,rgba(255,255,255,0.05)_40%,rgba(0,0,0,0.1)_100%)]" />

                  {/* Left panel */}
                  <motion.div
                    animate={{
                      rotateY: isOpening ? -92 : 0,
                      opacity: isOpening ? 0.35 : 1,
                    }}
                    transition={{
                      duration: 0.85,
                      ease: [0.76, 0, 0.24, 1],
                    }}
                    className="absolute left-0 top-0 h-full w-1/2 origin-left bg-black/5"
                    style={{ transformStyle: "preserve-3d" }}
                  >
                    <div className="absolute inset-0 border-r-2 border-[#111]" />
                    <div className="absolute left-0 top-[33%] h-[3px] w-full bg-[#111]" />
                    <div className="absolute left-0 top-[70%] h-[3px] w-full bg-[#111]" />
                  </motion.div>

                  {/* Right panel */}
                  <motion.div
                    animate={{
                      rotateY: isOpening ? 92 : 0,
                      opacity: isOpening ? 0.35 : 1,
                    }}
                    transition={{
                      duration: 0.85,
                      ease: [0.76, 0, 0.24, 1],
                    }}
                    className="absolute right-0 top-0 h-full w-1/2 origin-right bg-black/5"
                    style={{ transformStyle: "preserve-3d" }}
                  >
                    <div className="absolute inset-0 border-l-2 border-[#111]" />
                    <div className="absolute left-0 top-[33%] h-[3px] w-full bg-[#111]" />
                    <div className="absolute left-0 top-[70%] h-[3px] w-full bg-[#111]" />
                  </motion.div>

                  {/* Middle divider */}
                  <motion.div
                    animate={{ opacity: isOpening ? 0 : 1 }}
                    transition={{ duration: 0.3 }}
                    className="absolute left-1/2 top-0 h-full w-[3px] -translate-x-1/2 bg-[#111]"
                  />

                  {/* Warm glow when window opens */}
                  <motion.div
                    animate={{ opacity: isOpening ? 1 : 0 }}
                    transition={{ duration: 0.7 }}
                    className="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,227,176,0.45),rgba(255,227,176,0.16)_35%,transparent_70%)]"
                  />
                </div>
              </div>

              {/* Sill */}
              <div className="absolute -bottom-9 left-[-40px] h-3 w-[410px] bg-[#8b806c] shadow-md" />
              <div className="absolute -bottom-6 left-[-28px] h-4 w-[386px] bg-[#b3a184]" />
            </div>
          </motion.button>

          {/* Right content */}
          <motion.div
            animate={{
              opacity: isOpening ? 0.2 : 1,
              x: isOpening ? 28 : 0,
            }}
            transition={{
              duration: 0.8,
              ease: [0.76, 0, 0.24, 1],
            }}
            className="relative pl-[5vw]"
          >
            {/* Pendant wire */}
            <div className="absolute -top-[40vh] left-[43%] h-[42vh] w-px bg-[#211d18]" />

            {/* Pendant lamp */}
            <div className="absolute -top-[22vh] left-[33%]">
              <div className="relative h-[120px] w-[145px]">
                <div className="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(255,209,128,0.58),rgba(255,209,128,0.1)_55%,transparent_72%)] blur-2xl" />
                <div className="relative h-[115px] w-[145px] bg-[#4a3723] shadow-[0_18px_40px_rgba(0,0,0,0.45)] [clip-path:polygon(28%_0,72%_0,100%_100%,0_100%)]">
                  <div className="absolute inset-x-4 bottom-2 h-6 rounded-[50%] bg-[#e2b164]" />
                  <div className="absolute inset-0 bg-[linear-gradient(90deg,rgba(255,255,255,0.25),transparent_35%,rgba(0,0,0,0.28))]" />
                </div>
              </div>
            </div>

            <p className="mb-7 tracking-[0.42em] text-[13px] font-semibold uppercase text-[#5f5a50]">
              Architecture Studio
            </p>

            <h1 className="max-w-[620px] font-serif text-[64px] leading-[0.98] tracking-[-0.04em] text-[#4b463d]">
              DK Construction
              <br />
              &amp; Consultancy
            </h1>

            <p className="mt-7 text-[17px] font-medium tracking-wide text-[#5b564e]">
              Architecture · Interiors · Construction Consultancy
            </p>

            <div className="mt-10">
              <p className="mb-4 text-[17px] text-[#5b564e]">
                Designing refined spaces with,
              </p>

              {["Clarity", "Function", "Purpose"].map((item) => (
                <div
                  key={item}
                  className="flex max-w-[430px] items-center gap-4"
                >
                  <span className="w-[150px] font-serif text-[42px] italic leading-[1.25] tracking-[-0.03em] text-[#504b43]">
                    {item}
                  </span>

                  <span className="h-px flex-1 bg-[#7d705d]/45" />

                  <span className="h-1.5 w-1.5 rounded-full bg-[#34302a]" />
                </div>
              ))}
            </div>

            <p className="mt-12 text-[14px] text-[#5b564e]">
              Click the window to enter
              <span className="mt-2 block h-px w-[120px] bg-[#6b6254]" />
            </p>
          </motion.div>
        </motion.div>
      </div>
    </motion.section>
  );
}
