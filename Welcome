}

// Individual glass pane with wood frame + muntins
function WindowPane({
  side,
  rotateY,
  opacity,
}: {
  side: "left" | "right";
  rotateY: MotionValue<number>;
  opacity: MotionValue<number>;
}) {
  const isLeft = side === "left";

  return (
    <motion.div
      style={{
        rotateY,
        transformOrigin: isLeft ? "left center" : "right center",
        opacity,
      }}
      className={`pointer-events-none absolute top-0 z-[30] h-full w-1/2 ${
        isLeft ? "left-0" : "right-0"
      }`}
    >
      {/* Wood frame outer */}
      <div
        className="absolute inset-0"
        style={{
          background: `
            linear-gradient(
              ${isLeft ? "90deg" : "270deg"},
              #1a110a 0%,
              #3d2410 6%,
              #5c3418 16%,
              #2e1a0c 32%,
              #4a2a12 50%,
              #3a2010 68%,
              #5a3218 82%,
              #2c1a0c 94%,
              #1a110a 100%
            )
          `,
        }}
      />

      {/* Glass pane — full panel bg, visible through inner cutout */}
      <div
        className="absolute"
        style={{
          inset: "clamp(10px, 1.8vw, 18px)",
          background: isLeft
            ? "linear-gradient(135deg, rgba(180,215,235,0.52) 0%, rgba(140,190,215,0.32) 40%, rgba(200,230,245,0.22) 70%, rgba(120,175,205,0.42) 100%)"
            : "linear-gradient(225deg, rgba(180,215,235,0.52) 0%, rgba(140,190,215,0.32) 40%, rgba(200,230,245,0.22) 70%, rgba(120,175,205,0.42) 100%)",
          backdropFilter: "blur(3px) saturate(1.15)",
          boxShadow: "inset 0 0 0 0.5px rgba(200,230,250,0.3), inset 0 0 30px rgba(0,0,0,0.12)",
        }}
      >
        {/* Glass sheen diagonal streak */}
        <div
          className="absolute"
          style={{
            top: 0,
            left: isLeft ? "12%" : "auto",
            right: isLeft ? "auto" : "12%",
            width: "28%",
            height: "100%",
            background: `linear-gradient(${isLeft ? "150deg" : "210deg"}, rgba(255,255,255,0.13) 0%, rgba(255,255,255,0.04) 50%, transparent 100%)`,
            pointerEvents: "none",
          }}
        />
        {/* Secondary sheen */}
        <div
          className="absolute"
          style={{
            top: "10%",
            left: isLeft ? "45%" : "auto",
            right: isLeft ? "auto" : "45%",
            width: "15%",
            height: "70%",
            background: "linear-gradient(180deg, rgba(255,255,255,0.07) 0%, transparent 100%)",
          }}
        />
      </div>

      {/* HORIZONTAL MUNTIN — middle crossbar */}
      <div
        className="absolute left-0 right-0"
        style={{
          top: "50%",
          height: "clamp(8px, 1.4vh, 14px)",
          transform: "translateY(-50%)",
          background:
            "linear-gradient(180deg, #4a2a14 0%, #6b3a1c 25%, #3a1e0c 50%, #5c3018 75%, #2a1608 100%)",
          boxShadow: "0 2px 6px rgba(0,0,0,0.55), inset 0 1px 0 rgba(180,120,60,0.25)",
        }}
      />

      {/* VERTICAL MUNTIN — centre */}
      <div
        className="absolute top-0 bottom-0"
        style={{
          left: "50%",
          width: "clamp(7px, 1.2vw, 12px)",
          transform: "translateX(-50%)",
          background:
            "linear-gradient(90deg, #2a1608 0%, #5c3018 20%, #3a1e0c 50%, #6b3a1c 80%, #2a1608 100%)",
          boxShadow: "2px 0 6px rgba(0,0,0,0.45), inset 1px 0 0 rgba(180,120,60,0.2)",
        }}
      />

      {/* FRAME bevel highlights */}
      {/* Top inner highlight */}
      <div
        className="absolute left-0 right-0"
        style={{
          top: "clamp(9px, 1.7vw, 17px)",
          height: "1px",
          background: "rgba(160,100,40,0.35)",
        }}
      />
      {/* Left inner highlight */}
      <div
        className="absolute top-0 bottom-0"
        style={{
          left: "clamp(9px, 1.7vw, 17px)",
          width: "1px",
          background: "rgba(160,100,40,0.3)",
        }}
      />

      {/* HINGES */}
      <Hinge top="16%" side={side} />
      <Hinge top="50%" side={side} />
      <Hinge top="84%" side={side} />

      {/* HANDLE */}
      <Handle side={side} />
    </motion.div>
  );
}

export default function WelcomeWindow({
  isActive,
  leftRotate,
  rightRotate,
  windowScale,
  windowOpacity,
  windowExitX,
  frameOpacity,
  scrollTextOpacity,
  onEnterClick,
