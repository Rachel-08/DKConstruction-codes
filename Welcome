        {/* subtle plaster noise */}
        <div className="absolute inset-0 opacity-[0.10] [background-image:radial-gradient(circle_at_30%_20%,rgba(255,255,255,0.45)_0_1px,transparent_2px),radial-gradient(circle_at_70%_60%,rgba(0,0,0,0.4)_0_1px,transparent_2px)] [background-size:28px_28px]" />

        {/* uneven wall lighting */}
