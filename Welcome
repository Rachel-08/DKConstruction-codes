  const isLeft = side === "left";
  return (
    <div
      className="pointer-events-none absolute z-[50] top-1/2 -translate-y-1/2"
      style={{
        [isLeft ? "right" : "left"]: "clamp(4px, 1.2vw, 12px)",
        width: "clamp(16px, 2.2vw, 26px)",
        height: "clamp(60px, 10vh, 88px)",
      }}
    >
      <svg
        viewBox="0 0 26 88"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        className="h-full w-full drop-shadow-[0_3px_6px_rgba(0,0,0,0.8)]"
      >
        <defs>
          <linearGradient id={`esc-${side}`} x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stopColor="#f5c848" />
            <stop offset="20%" stopColor="#e0a020" />
            <stop offset="50%" stopColor="#f8cc50" />
            <stop offset="75%" stopColor="#b07818" />
            <stop offset="100%" stopColor="#f0b830" />
          </linearGradient>
          <linearGradient id={`lever-${side}`} x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stopColor="#e8aa28" />
            <stop offset="15%" stopColor="#fad060" />
            <stop offset="45%" stopColor="#c88820" />
            <stop offset="70%" stopColor="#f5c040" />
            <stop offset="100%" stopColor="#906010" />
          </linearGradient>
        </defs>
        {/* Escutcheon plate */}
        <rect x="3" y="1" width="20" height="86" rx="5" fill={`url(#esc-${side})`} />
        <rect x="3" y="1" width="20" height="86" rx="5" fill="none" stroke="#f8d870" strokeWidth="0.6" opacity="0.55" />
        {/* Keyhole slot */}
        <circle cx="13" cy="72" r="4" fill="#5a3800" />
        <rect x="11" y="72" width="4" height="8" rx="1" fill="#5a3800" />
        {/* Escutcheon screws */}
        <circle cx="13" cy="8" r="3.5" fill="#c88820" />
        <line x1="10.5" y1="8" x2="15.5" y2="8" stroke="#5a3800" strokeWidth="1" />
        <line x1="13" y1="5.5" x2="13" y2="10.5" stroke="#5a3800" strokeWidth="1" />
