              Architecture · Interiors · Construction Consultancy
            </p>

            <p className="mt-10 text-[13px] text-[#3b342c]/75">
              Designing refined spaces with,
            </p>

            <motion.p
              key={focusWords[activeWordIndex]}
              initial={{ opacity: 0, y: 12 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ duration: 0.45 }}
              className="mt-4 font-serif text-[3.4rem] italic tracking-[-0.05em]"
            >
              {focusWords[activeWordIndex]}
