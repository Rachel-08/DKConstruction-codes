"use client";

import { motion, type MotionValue } from "motion/react";

type WelcomeWindowProps = {
  isActive: boolean;
  leftRotate: MotionValue<number>;
  rightRotate: MotionValue<number>;
  windowScale: MotionValue<number>;
  windowOpacity: MotionValue<number>;
  windowExitX: MotionValue<string>;
  frameOpacity: MotionValue<number>;
  scrollTextOpacity: MotionValue<number>;
  onEnterClick: () => void;
};

// Reusable hinge SVG — renders a realistic brass hinge at a given top offset (in %)
function Hinge({ top, side }: { top: string; side: "left" | "right" }) {
  const isLeft = side === "left";
  return (
    <div
      className="pointer-events-none absolute z-[50]"
      style={{
        top,
        [isLeft ? "right" : "left"]: "-1px",
        transform: "translateY(-50%)",
        width: "clamp(14px, 2vw, 22px)",
        height: "clamp(36px, 6vh, 56px)",
      }}
    >
      <svg
        viewBox="0 0 22 56"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        className="h-full w-full drop-shadow-[0_2px_4px_rgba(0,0,0,0.7)]"
      >
        <defs>
          <linearGradient id={`hinge-face-${side}-${top}`} x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stopColor="#f5c84a" />
            <stop offset="18%" stopColor="#e0a020" />
            <stop offset="40%" stopColor="#f8d060" />
            <stop offset="60%" stopColor="#c88820" />
            <stop offset="80%" stopColor="#f0b830" />
            <stop offset="100%" stopColor="#8a6010" />
          </linearGradient>
          <linearGradient id={`hinge-knuckle-${side}-${top}`} x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stopColor="#f8d060" />
            <stop offset="35%" stopColor="#c08020" />
            <stop offset="65%" stopColor="#e8aa30" />
            <stop offset="100%" stopColor="#906010" />
          </linearGradient>
        </defs>
        {/* Hinge plate */}
        <rect x="1" y="1" width="20" height="54" rx="2" fill={`url(#hinge-face-${side}-${top})`} />
        <rect x="1" y="1" width="20" height="54" rx="2" fill="none" stroke="#f8d870" strokeWidth="0.5" opacity="0.6" />
        {/* Knuckle centre barrel */}
        <rect x="7" y="18" width="8" height="20" rx="2" fill={`url(#hinge-knuckle-${side}-${top})`} />
        <ellipse cx="11" cy="18" rx="4" ry="3.5" fill="#f8d060" />
        <ellipse cx="11" cy="38" rx="4" ry="3.5" fill="#a07018" />
        <line x1="11" y1="18" x2="11" y2="38" stroke="#c89028" strokeWidth="0.5" />
        {/* Pin dot */}
        <circle cx="11" cy="28" r="2" fill="#906010" />
        <circle cx="11" cy="28" r="1" fill="#c89028" />
        {/* Screws */}
        <circle cx="5.5" cy="7" r="3" fill="#c88820" />
        <line x1="3.5" y1="7" x2="7.5" y2="7" stroke="#604000" strokeWidth="0.9" />
        <line x1="5.5" y1="5" x2="5.5" y2="9" stroke="#604000" strokeWidth="0.9" />
        <circle cx="16.5" cy="7" r="3" fill="#c88820" />
        <line x1="14.5" y1="7" x2="18.5" y2="7" stroke="#604000" strokeWidth="0.9" />
        <line x1="16.5" y1="5" x2="16.5" y2="9" stroke="#604000" strokeWidth="0.9" />
        <circle cx="5.5" cy="49" r="3" fill="#c88820" />
        <line x1="3.5" y1="49" x2="7.5" y2="49" stroke="#604000" strokeWidth="0.9" />
        <line x1="5.5" y1="47" x2="5.5" y2="51" stroke="#604000" strokeWidth="0.9" />
        <circle cx="16.5" cy="49" r="3" fill="#c88820" />
        <line x1="14.5" y1="49" x2="18.5" y2="49" stroke="#604000" strokeWidth="0.9" />
        <line x1="16.5" y1="47" x2="16.5" y2="51" stroke="#604000" strokeWidth="0.9" />
      </svg>
    </div>
  );
}

// Reusable handle — escutcheon plate + lever knob
