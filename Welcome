"use client";

import { useEffect, useRef, useState, useCallback } from "react";
import { motion, AnimatePresence, type MotionValue } from "motion/react";

type WelcomeWindowProps = {
  isActive: boolean;
  leftRotate: MotionValue<number>;
  rightRotate: MotionValue<number>;
  windowScale: MotionValue<number>;
  windowOpacity: MotionValue<number>;
  windowExitX: MotionValue<string>;
  frameOpacity: MotionValue<number>;
  scrollTextOpacity: MotionValue<number>;
  onEnterClick: () => void;
  // Passed from parent so WelcomeWindow knows loading is done
  loadingComplete: boolean;
};

// ─── Hinge ───────────────────────────────────

function Hinge({ top, side }: { top: string; side: "left" | "right" }) {
  const isLeft = side === "left";
  return (
    <div
      className="pointer-events-none absolute z-[50]"
      style={{
        top,
        [isLeft ? "left" : "right"]: 0,
        transform: "translateY(-50%)",
        width: "clamp(12px, 1.6vw, 18px)",
        height: "clamp(32px, 5.5vh, 50px)",
      }}
    >
      <svg
        viewBox="0 0 18 50"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        className="h-full w-full"
        style={{ filter: "drop-shadow(0 2px 5px rgba(0,0,0,0.9))" }}
      >
        <defs>
          <linearGradient id={`hf-${side}-${top}`} x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%"   stopColor="#111" />
            <stop offset="22%"  stopColor="#4a4a4a" />
            <stop offset="48%"  stopColor="#7a7a7a" />
            <stop offset="65%"  stopColor="#595959" />
            <stop offset="85%"  stopColor="#2e2e2e" />
            <stop offset="100%" stopColor="#0d0d0d" />
          </linearGradient>
          <linearGradient id={`hk-${side}-${top}`} x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%"   stopColor="#888" />
            <stop offset="28%"  stopColor="#3a3a3a" />
            <stop offset="62%"  stopColor="#666" />
            <stop offset="100%" stopColor="#1a1a1a" />
          </linearGradient>
        </defs>
        <rect x="1" y="1" width="16" height="48" rx="1.5"
          fill={`url(#hf-${side}-${top})`} />
        <rect x="1" y="1" width="16" height="48" rx="1.5"
          fill="none" stroke="#888" strokeWidth="0.3" opacity="0.35" />
        <line x1="1" y1="1" x2="17" y2="1"
          stroke="#999" strokeWidth="0.4" opacity="0.5" />
        <rect x="5" y="15" width="8" height="20" rx="2"
          fill={`url(#hk-${side}-${top})`} />
        <ellipse cx="9" cy="15" rx="4" ry="3" fill="#777" />
        <ellipse cx="9" cy="35" rx="4" ry="3" fill="#2a2a2a" />
        <circle cx="9" cy="25" r="1.8" fill="#111" />
        <circle cx="9" cy="25" r="0.8" fill="#555" />
        <circle cx="4.5"  cy="6.5"  r="2" fill="#333" />
        <line x1="2.8"  y1="6.5"  x2="6.2"  y2="6.5"  stroke="#111" strokeWidth="0.7" />
        <circle cx="13.5" cy="6.5"  r="2" fill="#333" />
        <line x1="11.8" y1="6.5"  x2="15.2" y2="6.5"  stroke="#111" strokeWidth="0.7" />
        <circle cx="4.5"  cy="43.5" r="2" fill="#333" />
        <line x1="2.8"  y1="43.5" x2="6.2"  y2="43.5" stroke="#111" strokeWidth="0.7" />
        <circle cx="13.5" cy="43.5" r="2" fill="#333" />
        <line x1="11.8" y1="43.5" x2="15.2" y2="43.5" stroke="#111" strokeWidth="0.7" />
      </svg>
    </div>
  );
}

// ─── Handle ──────────────────────────────────

function Handle({ side }: { side: "left" | "right" }) {
  const isLeft = side === "left";
  return (
    <div
      className="pointer-events-none absolute z-[50] top-1/2 -translate-y-1/2"
      style={{
        [isLeft ? "right" : "left"]: "clamp(5px, 0.9vw, 9px)",
        width:  "clamp(7px, 0.9vw, 11px)",
        height: "clamp(40px, 7vh, 62px)",
      }}
    >
      <svg
        viewBox="0 0 11 62"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        className="h-full w-full"
        style={{ filter: "drop-shadow(1px 2px 5px rgba(0,0,0,0.9))" }}
      >
        <defs>
          <linearGradient id={`hd-${side}`} x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%"   stopColor="#111" />
            <stop offset="22%"  stopColor="#585858" />
            <stop offset="50%"  stopColor="#909090" />
            <stop offset="74%"  stopColor="#484848" />
            <stop offset="100%" stopColor="#111" />
          </linearGradient>
          <linearGradient id={`hd-cap-${side}`} x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%"   stopColor="#777" />
            <stop offset="100%" stopColor="#222" />
          </linearGradient>
        </defs>
        <ellipse cx="5.5" cy="5"  rx="3.5" ry="2.5" fill={`url(#hd-cap-${side})`} />
        <rect    x="2"   y="5"  width="7" height="52" rx="3.5"
          fill={`url(#hd-${side})`} />
        <rect x="4" y="8" width="2" height="46" rx="1"
          fill="white" opacity="0.09" />
        <ellipse cx="5.5" cy="57" rx="3.5" ry="2.5" fill="#1e1e1e" />
        <ellipse cx="5.5" cy="57" rx="3.5" ry="2.5"
          fill="none" stroke="#444" strokeWidth="0.4" />
