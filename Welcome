  const [activeWordIndex, setActiveWordIndex] = useState(0);

  useEffect(() => {
    if (!isActive) return;

    const interval = window.setInterval(() => {
      setActiveWordIndex((prev) => (prev + 1) % focusWords.length);
    }, 1450);

    return () => window.clearInterval(interval);
  }, [isActive]);

  return (
