                {/* outer shade shape */}
                <div className="absolute inset-0 overflow-hidden rounded-t-[22px] rounded-b-[54%] bg-[linear-gradient(100deg,#211812_0%,#4d3825_20%,#8b6a45_45%,#3a2a1e_72%,#1f1712_100%)] shadow-[0_18px_32px_rgba(26,18,12,0.42),inset_10px_0_18px_rgba(255,232,183,0.13),inset_-18px_0_24px_rgba(0,0,0,0.42)]">
                  {/* left highlight */}
                  <div className="absolute left-[25%] top-[4px] h-[95%] w-[24px] rotate-[7deg] rounded-full bg-white/12 blur-[9px]" />

                  {/* center bronze glow */}
                  <div className="absolute left-1/2 top-[8px] h-[85%] w-[58px] -translate-x-1/2 rounded-full bg-[#c08b4e]/20 blur-[18px]" />

                  {/* right dark edge */}
                  <div className="absolute right-0 top-0 h-full w-[42px] bg-black/32 blur-[8px]" />

                  {/* top rim */}
                  <div className="absolute left-1/2 top-0 h-[18px] w-[112px] -translate-x-1/2 rounded-full bg-[linear-gradient(90deg,#2b1f17,#7b5d3b,#241a13)] shadow-[inset_0_3px_7px_rgba(255,255,255,0.08)]" />

                  {/* inner warm bulb reflection */}
                  <div className="absolute bottom-[13px] left-1/2 h-[28px] w-[122px] -translate-x-1/2 rounded-full bg-[#ffd991] blur-[9px]" />

                  {/* visible bottom opening */}
                  <div className="absolute bottom-[1px] left-1/2 h-[25px] w-[122px] -translate-x-1/2 rounded-full bg-[radial-gradient(circle_at_center,#ffe5a8_0%,#ffd17c_42%,#8a5f35_78%,#312116_100%)] shadow-[0_0_18px_rgba(255,207,121,0.55)]" />

                  {/* black lower lip */}
                  <div className="absolute bottom-[-2px] left-1/2 h-[9px] w-[130px] -translate-x-1/2 rounded-full border-t border-black/45 bg-black/18" />
                </div>
              </div>

              {/* main light pool on wall */}
              <div className="absolute left-1/2 top-[24vh] h-[310px] w-[470px] -translate-x-1/2 rounded-full bg-[radial-gradient(ellipse_at_center,rgba(255,220,151,0.52)_0%,rgba(255,211,132,0.34)_28%,rgba(255,197,104,0.16)_52%,transparent_74%)] blur-[34px]" />

              {/* sharper light directly below lamp */}
              <div className="absolute left-1/2 top-[25.2vh] h-[175px] w-[310px] -translate-x-1/2 rounded-full bg-[radial-gradient(ellipse_at_center,rgba(255,230,174,0.46)_0%,rgba(255,208,125,0.24)_48%,transparent_72%)] blur-[24px]" />

              {/* soft cone shadow falloff like mockup */}
              <div className="absolute left-1/2 top-[20.5vh] h-[330px] w-[560px] -translate-x-1/2 bg-[radial-gradient(ellipse_at_top,rgba(255,216,145,0.24)_0%,rgba(255,205,124,0.14)_36%,transparent_68%)] blur-[18px]" />

              {/* darker shade shadow above light */}
              <div className="absolute left-1/2 top-[20.4vh] h-[58px] w-[220px] -translate-x-1/2 rounded-full bg-black/18 blur-[24px]" />
            </div>

            {/* TEXT CONTENT */}
            <div className="relative z-20 max-w-[700px] translate-y-[3.8vh] text-[#342d25]">
              <p className="mb-6 text-[12px] font-semibold uppercase tracking-[0.58em] text-[#40382f]/70">
                Architecture Studio
              </p>

              <h1 className="font-serif text-[clamp(4.5rem,6.75vw,7.25rem)] leading-[0.91] tracking-[-0.075em] text-[#3a332b]">
                DK Construction
                <br />
                <span>&amp; Consultancy</span>
              </h1>

              <p className="mt-7 text-[15px] font-light tracking-[0.015em] text-[#3b342c]/78">
                Architecture · Interiors · Construction Consultancy
              </p>

              <div className="mt-12">
                <p className="mb-5 text-[14px] leading-relaxed text-[#3b342c]/78">
                  Designing refined spaces with,
                </p>

                <div className="space-y-2">
                  {focusWords.map((word, index) => {
                    const active = activeWordIndex === index;

                    return (
                      <motion.div
                        key={word}
                        animate={{
                          opacity: active ? 1 : 0.38,
                          x: active ? 0 : -5,
                        }}
                        transition={{ duration: 0.45, ease: "easeOut" }}
                        className="flex max-w-[500px] items-center gap-5"
                      >
                        <span
                          className={`font-serif italic leading-none tracking-[-0.05em] transition-all duration-500 ${
                            active
                              ? "text-[clamp(3rem,4.25vw,4.6rem)] text-[#342d25]"
                              : "text-[clamp(2.55rem,3.6vw,3.75rem)] text-[#342d25]/72"
                          }`}
                        >
                          {word}
                        </span>

                        <div className="h-px flex-1 bg-[#3b342c]/18" />

                        <motion.div
                          animate={{
                            scale: active ? 1.25 : 1,
                            opacity: active ? 1 : 0.35,
                          }}
                          transition={{ duration: 0.45, ease: "easeOut" }}
                          className="h-[5px] w-[5px] rounded-full bg-[#342d25]"
                        />
                      </motion.div>
                    );
                  })}
                </div>
              </div>

              {/* CLICK INDICATOR */}
              <motion.div
                style={{ opacity: scrollTextOpacity }}
                className="mt-11 inline-flex flex-col items-start"
              >
                <p className="text-[13px] font-light tracking-wide text-[#3b342c]/72">
                  Click to enter
                </p>

                <motion.div
                  animate={{ scaleX: [0.35, 1, 0.35] }}
                  transition={{
                    duration: 1.8,
                    repeat: Infinity,
                    ease: "easeInOut",
                  }}
                  className="mt-2 h-px w-[88px] origin-left bg-[#3b342c]/35"
                />
              </motion.div>
            </div>
          </motion.div>
        </div>

        {/* MOBILE VERSION */}
        <div className="relative flex h-screen w-full items-center justify-center px-6 text-center md:hidden">
          <div className="absolute inset-0 bg-[#c7b697]" />
          <div className="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_42%,rgba(33,25,18,0.25)_100%)]" />

          <motion.div
            style={{ opacity: frameOpacity }}
