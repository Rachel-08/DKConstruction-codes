  );
}

// ─── WindowPane ──────────────────────────────

function WindowPane({
  side,
  rotateY,
  opacity,
}: {
  side: "left" | "right";
  rotateY: MotionValue<number>;
  opacity: MotionValue<number>;
}) {
  const isLeft = side === "left";
  return (
    <motion.div
      style={{
        rotateY,
        transformOrigin: isLeft ? "left center" : "right center",
        opacity,
      }}
      className={`pointer-events-none absolute top-0 z-[30] h-full w-1/2 ${
        isLeft ? "left-0" : "right-0"
      }`}
    >
      <div
        className="absolute inset-0"
        style={{
          background: isLeft
            ? "linear-gradient(90deg,#080503 0%,#180c05 9%,#241006 20%,#110803 35%,#1c0d05 50%,#130804 68%,#200e06 82%,#100703 94%,#080503 100%)"
            : "linear-gradient(270deg,#080503 0%,#180c05 9%,#241006 20%,#110803 35%,#1c0d05 50%,#130804 68%,#200e06 82%,#100703 94%,#080503 100%)",
        }}
      />
      <div
        className="absolute"
        style={{
          inset: "clamp(10px, 1.8vw, 18px)",
          background: isLeft
            ? "linear-gradient(135deg,rgba(155,195,218,0.46) 0%,rgba(115,170,198,0.26) 42%,rgba(180,218,236,0.16) 72%,rgba(95,155,188,0.36) 100%)"
            : "linear-gradient(225deg,rgba(155,195,218,0.46) 0%,rgba(115,170,198,0.26) 42%,rgba(180,218,236,0.16) 72%,rgba(95,155,188,0.36) 100%)",
          backdropFilter: "blur(2px) saturate(1.1)",
          boxShadow: "inset 0 0 0 0.5px rgba(170,210,232,0.2), inset 0 0 22px rgba(0,0,0,0.18)",
        }}
      >
        <div
          className="absolute"
          style={{
            top: 0,
            left:  isLeft ? "10%" : "auto",
            right: isLeft ? "auto" : "10%",
            width: "24%",
            height: "100%",
            background: `linear-gradient(${isLeft ? "148deg" : "212deg"},rgba(255,255,255,0.1) 0%,rgba(255,255,255,0.02) 55%,transparent 100%)`,
          }}
        />
      </div>
      <div
        className="absolute left-0 right-0"
        style={{
          top: "50%",
          height: "clamp(6px, 1.1vh, 11px)",
          transform: "translateY(-50%)",
          background: "linear-gradient(180deg,#2e2418 0%,#14100a 20%,#080604 42%,#181209 62%,#241a10 80%,#0a0806 100%)",
          boxShadow: "0 1px 0 rgba(255,255,255,0.055),0 -1px 0 rgba(255,255,255,0.035),0 3px 9px rgba(0,0,0,0.65),inset 0 1px 0 rgba(90,65,35,0.28)",
        }}
      />
      <div
        className="absolute top-0 bottom-0"
        style={{
          left: "50%",
          width: "clamp(5px, 0.9vw, 9px)",
          transform: "translateX(-50%)",
          background: "linear-gradient(90deg,#080604 0%,#241a10 20%,#0a0806 42%,#181209 62%,#2e2418 80%,#080604 100%)",
          boxShadow: "1px 0 0 rgba(255,255,255,0.05),-1px 0 0 rgba(255,255,255,0.03),3px 0 9px rgba(0,0,0,0.55),inset 1px 0 0 rgba(90,65,35,0.22)",
        }}
      />
      <Hinge top="16%" side={side} />
      <Hinge top="50%" side={side} />
      <Hinge top="84%" side={side} />
      <Handle side={side} />
    </motion.div>
  );
}

// ─── ScrollNudge indicator ───────────────────

function ScrollNudge({ visible }: { visible: boolean }) {
  return (
    <AnimatePresence>
      {visible && (
        <motion.div
          key="nudge"
          initial={{ opacity: 0, y: -6 }}
          animate={{ opacity: 1, y: 0 }}
          exit={{ opacity: 0, y: 6 }}
          transition={{ duration: 0.5, ease: [0.22, 1, 0.36, 1] }}
          className="pointer-events-none absolute bottom-8 left-1/2 -translate-x-1/2 z-[90] flex flex-col items-center gap-2"
        >
          {/* Pulsing chevrons */}
          {[0, 1, 2].map((i) => (
            <motion.div
              key={i}
              animate={{ opacity: [0.15, 0.7, 0.15], y: [0, 5, 0] }}
              transition={{
                duration: 1.4,
                repeat: Infinity,
                delay: i * 0.18,
                ease: "easeInOut",
              }}
            >
              <svg
                viewBox="0 0 16 9"
                fill="none"
                style={{ width: 14, height: 8 }}
              >
                <polyline
                  points="1,1 8,8 15,1"
                  stroke="rgba(0,0,0,0.45)"
                  strokeWidth="1.5"
                  strokeLinecap="round"
                  strokeLinejoin="round"
                />
              </svg>
            </motion.div>
          ))}
          <span
            className="font-mono uppercase tracking-[0.32em]"
            style={{ fontSize: 8, color: "rgba(0,0,0,0.35)" }}
          >
            Scroll
          </span>
        </motion.div>
      )}
    </AnimatePresence>
  );
}

// ─── WelcomeWindow ───────────────────────────

export default function WelcomeWindow({
  isActive,
  leftRotate,
  rightRotate,
  windowScale,
  windowOpacity,
  windowExitX,
  frameOpacity,
  scrollTextOpacity,
  onEnterClick,
  loadingComplete,
}: WelcomeWindowProps) {
  const idleTimer   = useRef<ReturnType<typeof setTimeout> | null>(null);
  const autoTimer   = useRef<ReturnType<typeof setTimeout> | null>(null);
  const [nudgeVisible, setNudgeVisible] = useState(false);

  // Auto-open the window shortly after loading completes
  useEffect(() => {
    if (!loadingComplete) return;
    const t = setTimeout(() => {
      onEnterClick();
    }, 1800); // 1.8s after loader exits — user sees the window briefly first
    return () => clearTimeout(t);
  }, [loadingComplete, onEnterClick]);

  // Idle nudge — show scroll hint after 2s of no scroll activity
  const resetIdleTimer = useCallback(() => {
    setNudgeVisible(false);
    if (idleTimer.current) clearTimeout(idleTimer.current);
    if (autoTimer.current) clearTimeout(autoTimer.current);

    idleTimer.current = setTimeout(() => {
      if (isActive) setNudgeVisible(true);
    }, 2000);
  }, [isActive]);

  useEffect(() => {
    if (!isActive) {
      setNudgeVisible(false);
      return;
    }
    resetIdleTimer();
    window.addEventListener("scroll", resetIdleTimer, { passive: true });
    window.addEventListener("wheel",  resetIdleTimer, { passive: true });
    window.addEventListener("touchmove", resetIdleTimer, { passive: true });
    return () => {
      window.removeEventListener("scroll", resetIdleTimer);
      window.removeEventListener("wheel",  resetIdleTimer);
      window.removeEventListener("touchmove", resetIdleTimer);
      if (idleTimer.current)  clearTimeout(idleTimer.current);
      if (autoTimer.current)  clearTimeout(autoTimer.current);
    };
  }, [isActive, resetIdleTimer]);

  return (
    <section
      className={`absolute inset-0 z-[80] ${
        isActive ? "pointer-events-auto" : "pointer-events-none"
      }`}
    >
      <motion.div
        role="button"
        tabIndex={isActive ? 0 : -1}
        aria-label="Enter website"
        onClick={onEnterClick}
        onKeyDown={(e) => {
          if (e.key === "Enter" || e.key === " ") {
            e.preventDefault();
            onEnterClick();
          }
        }}
        style={{
          scale:   windowScale,
          opacity: windowOpacity,
          x:       windowExitX,
        }}
        className="absolute inset-0 flex cursor-pointer items-center justify-center outline-none"
      >
        <div className="relative h-[58vh] w-[84vw] max-w-5xl overflow-hidden rounded-[18px] bg-[#080503] shadow-[0_40px_120px_rgba(0,0,0,0.5)] [perspective:1400px] md:h-[65vh] md:w-[78vw]">
          <motion.img
            src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?q=80&w=1800&auto=format&fit=crop"
            alt="Architecture view"
            draggable={false}
            className="absolute inset-0 h-full w-full select-none object-cover"
          />
          <div className="absolute inset-0 bg-black/10" />
          <motion.div
            style={{ opacity: frameOpacity }}
            className="pointer-events-none absolute inset-0 z-[20] rounded-[18px] border-[12px] border-[#0d0805] md:border-[14px]"
          />
          <motion.div
            style={{ opacity: frameOpacity }}
            className="pointer-events-none absolute left-1/2 top-0 z-[25] h-full w-[10px] -translate-x-1/2 bg-[#0d0805] md:w-[12px]"
          />
          <WindowPane side="left"  rotateY={leftRotate}  opacity={frameOpacity} />
          <WindowPane side="right" rotateY={rightRotate} opacity={frameOpacity} />
        </div>
      </motion.div>

      {/* Original scroll text — fades out as you scroll */}
      <motion.p
        style={{ opacity: scrollTextOpacity, x: windowExitX }}
        className="pointer-events-none absolute bottom-8 left-1/2 z-[90] -translate-x-1/2 text-[10px] uppercase tracking-[0.35em] text-black/60 md:bottom-10 md:text-xs"
      >
        Click anywhere on the window to enter
      </motion.p>

      {/* Idle scroll nudge */}
      <ScrollNudge visible={nudgeVisible} />
    </section>
  );
}
