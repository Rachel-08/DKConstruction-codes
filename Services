  const [status, setStatus] = useState<"idle" | "sending" | "sent" | "error">("idle");

  const handleSubmit = async () => {
    if (!form.name || !form.phone) return;
    setStatus("sending");

    const serviceList = services.map((s) => s.fullTitle).join(", ");
    const waMessage = `*New Project Enquiry*\n\n*Name:* ${form.name}\n*Phone:* ${form.phone}\n\n*Services Requested:*\n${services.map((s) => `• ${s.fullTitle}`).join("\n")}\n\n*Message:*\n${form.message || "—"}`;

    try {
      // WhatsApp Business API call
      // Replace PHONE_NUMBER_ID and ACCESS_TOKEN with your credentials
