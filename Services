                      style={{
                        fontSize: "clamp(6px,0.6vw,8px)",
                        color: "rgba(200,160,80,0.55)",
                        letterSpacing: "0.15em",
                      }}
                    >
                      <span
                        style={{
                          width: 14,
                          height: 0.5,
                          background: "rgba(200,160,80,0.3)",
                          flexShrink: 0,
                          display: "inline-block",
                        }}
                      />
                      {d.toUpperCase()}
                    </div>
                  ))}
                </div>
                {/* Drag hint */}
                <div
                  className="mt-1 font-mono text-center"
                  style={{
                    fontSize: "clamp(6px,0.55vw,8px)",
                    color: "rgba(200,160,80,0.35)",
