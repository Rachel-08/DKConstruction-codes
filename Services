// ─────────────────────────────────────────────
// ServicesSection
// ─────────────────────────────────────────────

export default function ServicesSection({
  isActive,
  servicesOpacity,
  servicesY,
  servicesExitY,
}: ServicesSectionProps) {
  const innerRef = useRef<HTMLDivElement>(null);

  // Internal scroll progress drives which service is shown
  // We use the parent servicesOpacity range (0.36 → 0.58) mapped to [0, 1]
  // But since we don't have access to raw scrollYProgress here,
  // we derive a normalised progress from servicesY reaching 0
  // The cleanest approach: accept a dedicated servicesProgress MotionValue from parent
  // For now we use a contained useScroll on the sticky wrapper via innerRef
  // (parent will need to pass servicesProgress — see note below)

  // ── We need the parent's scrollYProgress sliced to [0.36, 0.58]
  // Accept it as a prop: servicesProgress MotionValue<number> [0 → 1]
  // For now wired internally — see ScrollExperience update note at bottom

  return (
    <motion.section
      style={{
        opacity: servicesOpacity,
        y: isActive ? servicesExitY : servicesY,
        position: "absolute",
        inset: 0,
        zIndex: 70,
        pointerEvents: isActive ? "auto" : "none",
        background: "#000000",
      }}
      aria-hidden={!isActive}
    >
      {/* Section label — top left */}
      <div
        className="absolute top-[clamp(20px,3.5vh,36px)] left-[clamp(24px,4vw,56px)] z-[10] flex items-center gap-4"
      >
        <span
          className="font-mono uppercase tracking-[0.4em]"
          style={{
            fontSize: "clamp(8px,0.65vw,9px)",
            color: "rgba(200,160,80,0.4)",
          }}
        >
          Services
        </span>
        <div
          style={{
            width: "clamp(24px,3vw,40px)",
            height: "0.5px",
            background: "rgba(200,160,80,0.2)",
          }}
        />
      </div>

      {/* Slides container — all absolute stacked */}
      <ServicesDriver isActive={isActive} />
    </motion.section>
  );
}

// ─────────────────────────────────────────────
// ServicesDriver — owns its own scroll ref
// so slides are driven by the parent scroll
// ─────────────────────────────────────────────

function ServicesDriver({ isActive }: { isActive: boolean }) {
  // We rely on the window scroll since this sits inside a sticky viewport.
  // useScroll with no target tracks window scroll — same source as parent.
  const { scrollYProgress } = useScroll();

  // Remap the services slice [0.36 → 0.58] to [0 → 1]
  const servicesProgress = useTransform(
    scrollYProgress,
    [0.36, 0.58],
    [0, 1]
  );

  return (
    <div className="absolute inset-0">
      {SERVICES.map((service, i) => (
        <ServiceSlide
          key={service.id}
          service={service}
          index={i}
          progress={servicesProgress}
          totalServices={SERVICES.length}
        />
      ))}
    </div>
  );
}
