function ServiceColumn({
  service,
  index,
  total,
}: {
  service: Service;
  index: number;
  total: number;
}) {
  const [hovered, setHovered] = useState(false);
  const ref = useRef<HTMLDivElement>(null);

  return (
    <motion.div
      ref={ref}
      initial={{ opacity: 0, y: 32 }}
      animate={{ opacity: 1, y: 0 }}
      transition={{
        duration: 0.75,
        delay: index * 0.08,
        ease: [0.22, 1, 0.36, 1],
      }}
      onHoverStart={() => setHovered(true)}
      onHoverEnd={() => setHovered(false)}
      className="relative flex-1 overflow-hidden cursor-default"
      style={{
        borderRight:
          index < total - 1
            ? "0.5px solid rgba(200,160,80,0.1)"
            : undefined,
      }}
    >
      {/* Background image */}
      <motion.div
        animate={{ scale: hovered ? 1.06 : 1 }}
        transition={{ duration: 0.7, ease: [0.22, 1, 0.36, 1] }}
        className="absolute inset-0"
      >
        <img
          src={service.image}
          alt={service.fullTitle}
          draggable={false}
          className="absolute inset-0 w-full h-full object-cover select-none"
        />
      </motion.div>

      {/* Base dark overlay */}
      <div
        className="absolute inset-0"
        style={{
          background:
            "linear-gradient(180deg,rgba(0,0,0,0.55) 0%,rgba(0,0,0,0.3) 40%,rgba(0,0,0,0.75) 100%)",
        }}
      />

      {/* Hover warm tint */}
      <motion.div
        animate={{ opacity: hovered ? 1 : 0 }}
        transition={{ duration: 0.45 }}
        className="absolute inset-0"
        style={{
          background:
            "linear-gradient(180deg,rgba(20,12,4,0.4) 0%,rgba(30,18,6,0.2) 50%,rgba(10,6,2,0.6) 100%)",
        }}
      />

      {/* Content */}
      <div className="relative z-10 h-full flex flex-col justify-between p-[clamp(14px,2vw,26px)]">

        {/* Top — number */}
        <div className="flex items-center gap-2">
          <span
            className="font-mono"
            style={{
              fontSize: "clamp(7px,0.62vw,9px)",
              color: "rgba(200,160,80,0.5)",
              letterSpacing: "0.32em",
            }}
          >
            {service.number}
          </span>
          <motion.div
            animate={{ scaleX: hovered ? 1 : 0.2, opacity: hovered ? 0.5 : 0.15 }}
            transition={{ duration: 0.4 }}
            style={{
              transformOrigin: "left",
              flex: 1,
              height: "0.5px",
              background: "rgba(200,160,80,0.7)",
            }}
          />
        </div>

        {/* Bottom — keyword + title + details */}
        <div className="flex flex-col gap-3">

          {/* Keyword — large, always visible */}
          <motion.div
            animate={{ y: hovered ? -4 : 0 }}
            transition={{ duration: 0.4, ease: [0.22, 1, 0.36, 1] }}
          >
            <div
              className="absolute left-0 right-0"
              style={{
                bottom: hovered ? "auto" : undefined,
                padding: `clamp(8px,1.2vh,14px) clamp(14px,2vw,26px)`,
                backdropFilter: hovered ? "blur(12px) saturate(1.1)" : "blur(0px)",
                WebkitBackdropFilter: hovered ? "blur(12px) saturate(1.1)" : "blur(0px)",
                background: hovered ? "rgba(0,0,0,0.35)" : "transparent",
                borderTop: hovered ? "0.5px solid rgba(200,160,80,0.12)" : "none",
                transition: "all 0.4s cubic-bezier(0.22,1,0.36,1)",
                bottom: 0,
              }}
            >
              <h3
                className="font-serif font-bold leading-none"
                style={{
                  fontSize: "clamp(18px,2.8vw,44px)",
                  color: hovered ? "#fff8ee" : "rgba(240,225,195,0.82)",
                  letterSpacing: hovered ? "0.02em" : "0.06em",
                  transition: "all 0.4s cubic-bezier(0.22,1,0.36,1)",
                  writingMode: "vertical-lr",
                  textOrientation: "mixed",
                  transform: "rotate(180deg)",
                  height: "clamp(120px,20vh,260px)",
                  whiteSpace: "nowrap",
                  overflow: "hidden",
                  textOverflow: "ellipsis",
                }}
              >
                {service.keyword}
              </h3>
            </div>
          </motion.div>

          {/* Hover details */}
          <AnimatePresence>
            {hovered && (
              <motion.div
                initial={{ opacity: 0, y: 14 }}
                animate={{ opacity: 1, y: 0 }}
                exit={{ opacity: 0, y: 10 }}
                transition={{ duration: 0.38, ease: [0.22, 1, 0.36, 1] }}
                className="flex flex-col gap-2"
                style={{ paddingBottom: "clamp(80px,14vh,160px)" }}
              >
                <p
                  className="font-serif leading-relaxed"
                  style={{
                    fontSize: "clamp(9px,0.82vw,12px)",
