        animate={{ scaleX: hovered ? 1 : 0 }}
        transition={{ duration: 0.5, ease: [0.22, 1, 0.36, 1] }}
        style={{
          transformOrigin: "left",
          position: "absolute",
          top: 0,
          left: 0,
          right: 0,
          height: "1.5px",
          background: "linear-gradient(90deg,#c8a052,#e8c070,transparent)",
          zIndex: 20,
        }}
      />
    </motion.div>
  );
