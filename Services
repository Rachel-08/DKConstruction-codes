          </div>
<button
            onClick={onClose}
            className="font-mono mt-1"
            style={{
              fontSize: 11,
              color: "rgba(200,160,80,0.35)",
              letterSpacing: "0.2em",
              background: "none",
              border: "none",
              cursor: "pointer",
            }}
          >
            ✕
          </button>
        </div>

        {/* Selected services */}
        <div
          className="px-6 py-4 flex flex-wrap gap-2"
          style={{ borderBottom: "0.5px solid rgba(200,160,80,0.08)" }}
        >
          {services.map((s) => (
            <div
              key={s.id}
              className="font-mono"
style={{
                background: "rgba(200,160,80,0.08)",
                border: "0.5px solid rgba(200,160,80,0.25)",
                borderRadius: 2,
                padding: "3px 10px",
                fontSize: "clamp(6px,0.6vw,8px)",
                color: "rgba(200,160,80,0.65)",
                letterSpacing: "0.2em",
              }}
            >
              {s.number} {s.shortTitle.toUpperCase()}
            </div>
          ))}
        </div>

        {/* Form */}
        {status === "sent" ? (
          <motion.div
            initial={{ opacity: 0, y: 10 }}
            animate={{ opacity: 1, y: 0 }}
            className="p-8 flex flex-col items-center gap-4 text-center"
          >
            <div
style={{
                width: 48,
                height: 48,
                borderRadius: "50%",
                border: "1px solid rgba(200,160,80,0.4)",
                display: "flex",
                alignItems: "center",
                justifyContent: "center",
              }}
            >
              <svg viewBox="0 0 24 24" fill="none" style={{ width: 20, height: 20 }}>
                <polyline
                  points="4,12 9,17 20,7"
                  stroke="rgba(200,160,80,0.8)"
                  strokeWidth="1.5"
                />
              </svg>
            </div>
            <p
              className="font-serif"
              style={{ fontSize: "clamp(14px,1.4vw,18px)", color: "#e8d8b8" }}
            >
              Brief received
</p>
            <p
              className="font-mono"
              style={{
                fontSize: "clamp(7px,0.65vw,9px)",
                color: "rgba(200,160,80,0.45)",
                letterSpacing: "0.2em",
              }}
            >
              WE'LL BE IN TOUCH SHORTLY
            </p>
          </motion.div>
        ) : (
          <div className="p-6 flex flex-col gap-4">
            {/* Name */}
            <div className="flex flex-col gap-1.5">
              <label
                className="font-mono uppercase tracking-[0.25em]"
                style={{
                  fontSize: "clamp(6px,0.6vw,8px)",
                  color: "rgba(200,160,80,0.4)",
                }}
              >
                Name
</label>
              <input
                type="text"
                value={form.name}
                onChange={(e) => setForm((f) => ({ ...f, name: e.target.value }))}
                placeholder="Your full name"
                style={{
                  background: "rgba(255,255,255,0.03)",
                  border: "0.5px solid rgba(200,160,80,0.15)",
                  borderRadius: 2,
                  padding: "10px 14px",
                  fontSize: "clamp(10px,0.9vw,13px)",
                  color: "#e8d8b8",
                  outline: "none",
                  width: "100%",
                  fontFamily: "inherit",
                }}
                onFocus={(e) =>
                  (e.target.style.borderColor = "rgba(200,160,80,0.45)")
                }
                onBlur={(e) =>
                  (e.target.style.borderColor = "rgba(200,160,80,0.15)")
                }
              />
            </div>
{/* Phone */}
            <div className="flex flex-col gap-1.5">
              <label
                className="font-mono uppercase tracking-[0.25em]"
                style={{
                  fontSize: "clamp(6px,0.6vw,8px)",
                  color: "rgba(200,160,80,0.4)",
                }}
              >
                WhatsApp Number
              </label>
              <input
                type="tel"
                value={form.phone}
                onChange={(e) => setForm((f) => ({ ...f, phone: e.target.value }))}
                placeholder="+91 98765 43210"
                style={{
                  background: "rgba(255,255,255,0.03)",
                  border: "0.5px solid rgba(200,160,80,0.15)",
                  borderRadius: 2,
                  padding: "10px 14px",
                  fontSize: "clamp(10px,0.9vw,13px)",
                  color: "#e8d8b8",
                  outline: "none",
                  width: "100%",
fontFamily: "inherit",
                }}
                onFocus={(e) =>
                  (e.target.style.borderColor = "rgba(200,160,80,0.45)")
                }
                onBlur={(e) =>
                  (e.target.style.borderColor = "rgba(200,160,80,0.15)")
                }
              />
            </div>

            {/* Message */}
            <div className="flex flex-col gap-1.5">
              <label
                className="font-mono uppercase tracking-[0.25em]"
                style={{
                  fontSize: "clamp(6px,0.6vw,8px)",
                  color: "rgba(200,160,80,0.4)",
                }}
              >
                Message
              </label>
              <textarea
value={form.message}
                onChange={(e) => setForm((f) => ({ ...f, message: e.target.value }))}
                placeholder="Tell us about your project..."
                rows={3}
                style={{
                  background: "rgba(255,255,255,0.03)",
                  border: "0.5px solid rgba(200,160,80,0.15)",
                  borderRadius: 2,
                  padding: "10px 14px",
                  fontSize: "clamp(10px,0.9vw,13px)",
                  color: "#e8d8b8",
                  outline: "none",
                  width: "100%",
                  resize: "none",
                  fontFamily: "inherit",
                  lineHeight: 1.6,
                }}
                onFocus={(e) =>
                  (e.target.style.borderColor = "rgba(200,160,80,0.45)")
                }
                onBlur={(e) =>
                  (e.target.style.borderColor = "rgba(200,160,80,0.15)")
                }
              />
            </div>
{/* Submit */}
            <motion.button
              whileHover={{ scale: 1.01 }}
              whileTap={{ scale: 0.98 }}
              onClick={handleSubmit}
              disabled={status === "sending" || !form.name || !form.phone}
              style={{
                marginTop: 4,
                padding: "12px 24px",
                background:
                  form.name && form.phone
                    ? "linear-gradient(90deg, #c8a052, #e8c070, #b88840)"
                    : "rgba(200,160,80,0.15)",
                border: "none",
                borderRadius: 2,
                cursor: form.name && form.phone ? "pointer" : "not-allowed",
                fontFamily: "inherit",
                display: "flex",
                alignItems: "center",
                justifyContent: "center",
                gap: 8,
              }}
            >
<span
                className="font-mono uppercase tracking-[0.3em]"
                style={{
                  fontSize: "clamp(7px,0.65vw,9px)",
                  color:
                    form.name && form.phone ? "#0e0b07" : "rgba(200,160,80,0.35)",
                }}
              >
                {status === "sending" ? "Sending..." : "Send Brief via WhatsApp"}
              </span>
            </motion.button>

            {status === "error" && (
              <p
                className="font-mono text-center"
                style={{
                  fontSize: "clamp(6px,0.6vw,8px)",
                  color: "rgba(220,100,80,0.7)",
                  letterSpacing: "0.2em",
                }}
              >
                FAILED TO SEND — PLEASE TRY AGAIN
              </p>
            )}
          </div>
        )}
      </motion.div>
    </motion.div>
  );
}

