// ─────────────────────────────────────────────
// Each slide occupies 1/totalServices of progress
// e.g. 6 services → each gets ~0.167 of [0,1]
// Entry: 0.00 – 0.25 of its slice
// Rest:  0.25 – 0.75
// Exit:  0.75 – 1.00
// ─────────────────────────────────────────────

function ServiceSlide({ service, index, progress, totalServices }: ServiceSlideProps) {
  const sliceSize  = 1 / totalServices;
  const sliceStart = index * sliceSize;
  const sliceEnd   = sliceStart + sliceSize;

  const entryEnd = sliceStart + sliceSize * 0.28;
  const exitStart = sliceStart + sliceSize * 0.72;

  const isEven = index % 2 === 0;

  // Image: even → enters from right, odd → enters from left
  const imageX = useTransform(
    progress,
    [sliceStart, entryEnd, exitStart, sliceEnd],
    isEven
      ? ["120vw", "0vw", "0vw", "-120vw"]
      : ["-120vw", "0vw", "0vw", "120vw"]
  );

  // Details: even → enters from left, odd → enters from right
  const detailsX = useTransform(
    progress,
    [sliceStart, entryEnd, exitStart, sliceEnd],
    isEven
      ? ["-110vw", "0vw", "0vw", "110vw"]
      : ["110vw", "0vw", "0vw", "-110vw"]
  );

  // Fade — sharp in, held, sharp out
  const opacity = useTransform(
    progress,
    [sliceStart, entryEnd, exitStart, sliceEnd],
    [0, 1, 1, 0]
  );

  // Number counter fades opposite direction
  const numberOpacity = useTransform(
    progress,
    [sliceStart, entryEnd * 0.6, exitStart, sliceEnd],
    [0, 1, 1, 0]
  );

  return (
    <motion.div
      style={{ opacity }}
      className="absolute inset-0 flex items-center justify-center"
    >
      {/* ── Layout: image + details side by side ── */}
      <div className="relative w-full h-full flex items-center justify-center gap-0">

        {/* ── TALL PORTRAIT IMAGE ── */}
        <motion.div
          style={{ x: imageX }}
          className={`relative flex-shrink-0 overflow-hidden ${
            isEven ? "order-2" : "order-1"
          }`}
          // Tall portrait: 38vw wide, ~88vh tall
          style={{
            x: imageX,
            width: "clamp(260px, 38vw, 560px)",
            height: "clamp(420px, 86vh, 920px)",
            flexShrink: 0,
          }}
        >
          {/* Photo */}
          <img
            src={service.image}
            alt={service.fullTitle}
            draggable={false}
            className="absolute inset-0 w-full h-full object-cover select-none"
          />

          {/* Dark gradient overlay — heavier at bottom for text legibility */}
          <div
            className="absolute inset-0"
            style={{
              background:
                "linear-gradient(180deg, rgba(0,0,0,0.18) 0%, rgba(0,0,0,0.38) 40%, rgba(0,0,0,0.72) 100%)",
            }}
          />

          {/* Frosted blur strip behind service name */}
          <div
            className="absolute left-0 right-0"
            style={{
              bottom: "clamp(48px,10vh,100px)",
              padding: "clamp(16px,2.5vh,32px) clamp(20px,2.5vw,36px)",
              backdropFilter: "blur(14px) saturate(1.1)",
              WebkitBackdropFilter: "blur(14px) saturate(1.1)",
              background: "rgba(0,0,0,0.28)",
              borderTop: "0.5px solid rgba(200,160,80,0.18)",
              borderBottom: "0.5px solid rgba(200,160,80,0.1)",
            }}
          >
            {/* Service name — large and bold */}
            <h2
              className="font-serif font-bold leading-none tracking-tight text-white"
              style={{ fontSize: "clamp(22px,3.8vw,58px)" }}
            >
              {service.fullTitle}
            </h2>

            {/* Thin brass rule below name */}
            <div
              className="mt-3"
              style={{
                height: "1px",
                width: "40%",
                background:
                  "linear-gradient(90deg, #c8a052 0%, #e8c070 60%, transparent 100%)",
              }}
            />
          </div>

          {/* Service number — top corner */}
          <motion.span
            style={{ opacity: numberOpacity }}
            className="absolute top-[clamp(20px,3vh,36px)] left-[clamp(16px,2vw,28px)] font-mono"
            style={{
              fontSize: "clamp(9px,0.9vw,12px)",
              color: "rgba(200,160,80,0.7)",
              letterSpacing: "0.35em",
              opacity: numberOpacity,
            }}
          >
            {service.number}
          </motion.span>
        </motion.div>

        {/* ── DETAILS PANEL ── */}
        <motion.div
          style={{ x: detailsX }}
          className={`flex flex-col justify-center gap-[clamp(20px,3.5vh,40px)] ${
            isEven ? "order-1" : "order-2"
          }`}
